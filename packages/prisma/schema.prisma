generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String        @id @default(uuid()) @map("id")
  email             String        @unique @map("email")
  passwordHash      String        @map("password_hash")
  lastUsedTenantId  String?       @map("last_used_tenant_id")
  lastUsedTenant    Tenant?       @relation("LastUsedTenant", fields: [lastUsedTenantId], references: [id])
  userTenants       UserTenant[]
  auditLogs         AuditLog[]
  planTier          String        @map("plan_tier") @default("starter")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("users")
}

model Tenant {
  id             String            @id @default(uuid()) @map("id")
  name           String            @map("name")
  settings       TenantSetting?
  userTenants    UserTenant[]
  tenantMembers  TenantMember[]
  usersLastUsed  User[]            @relation("LastUsedTenant")
  auditLogs      AuditLog[]
  usageCounters  UsageCounter[]
  apiKeys        TenantApiKey[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@map("tenants")
}

model TenantSetting {
  id              String    @id @default(uuid()) @map("id")
  tenantId        String    @unique @map("tenant_id")
  planTier        String    @map("plan_tier")
  region          String    @map("region")
  capabilityFlags String[]  @map("capability_flags")
  metadata        Json?     @map("metadata")
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

model UserTenant {
  id          String   @id @default(uuid()) @map("id")
  userId      String   @map("user_id")
  tenantId    String   @map("tenant_id")
  role        String   @map("role")
  lastActiveAt DateTime? @map("last_active_at")
  user        User     @relation(fields: [userId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId], map: "user_tenants_user_id_tenant_id_key")
  @@map("user_tenants")
}

model AuditLog {
  id         String   @id @default(uuid()) @map("id")
  userId     String?  @map("user_id")
  tenantId   String?  @map("tenant_id")
  action     String   @map("action")
  targetId   String?  @map("target_id")
  ipAddress  String?  @map("ip_address")
  metadata   Json?    @map("metadata")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "audit_logs_tenant_id_idx")
  @@index([userId], map: "audit_logs_user_id_idx")
  @@map("audit_logs")
}

model TenantMember {
  id            String   @id @default(uuid()) @map("id")
  tenantId      String   @map("tenant_id")
  email         String   @map("email")
  role          String   @map("role")
  status        String   @default("pending") @map("status")
  inviteToken   String?  @unique @map("invite_token")
  invitedBy     String   @map("invited_by")
  acceptedAt    DateTime? @map("accepted_at")
  metadata      Json?    @map("metadata")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "tenant_members_tenant_id_idx")
  @@index([email], map: "tenant_members_email_idx")
  @@index([inviteToken], map: "tenant_members_invite_token_idx")
  @@unique([tenantId, email], map: "tenant_members_tenant_email_unique")
  @@map("tenant_members")
}

model PlanTier {
  id                  String   @id @default(uuid()) @map("id")
  name                String   @unique @map("name")
  displayName         String   @map("display_name")
  maxTenants          Int      @map("max_tenants")
  maxTeamMembers      Int      @map("max_team_members")
  maxMonthlySends     Int      @map("max_monthly_sends")
  maxAiTokensMonthly  Int      @map("max_ai_tokens_monthly")
  availableChannels   String[] @map("available_channels")
  capabilityFlags     String[] @map("capability_flags")
  metadata            Json?    @map("metadata")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([name], map: "plan_tiers_name_idx")
  @@map("plan_tiers")
}

model UsageCounter {
  id          String   @id @default(uuid()) @map("id")
  tenantId    String   @map("tenant_id")
  usageType   String   @map("usage_type")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  count       Int      @default(0) @map("count")
  metadata    Json?    @map("metadata")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, usageType, periodStart], map: "usage_counters_tenant_type_period_idx")
  @@index([tenantId], map: "usage_counters_tenant_id_idx")
  @@index([periodStart, periodEnd], map: "usage_counters_period_idx")
  @@map("usage_counters")
}

model TenantApiKey {
  id             String    @id @default(uuid()) @map("id")
  tenantId       String    @map("tenant_id")
  name           String    @map("name")
  description    String?   @map("description")
  hashedSecret   String    @map("hashed_secret")
  planTier       String    @map("plan_tier")
  scopeFlags     String[]  @map("scope_flags")
  revokedAt      DateTime? @map("revoked_at")
  revokedBy      String?   @map("revoked_by")
  lastUsedAt     DateTime? @map("last_used_at")
  lastRotatedAt  DateTime? @map("last_rotated_at")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "tenant_api_keys_tenant_id_idx")
  @@index([tenantId, revokedAt], map: "tenant_api_keys_tenant_id_status_idx")
  @@map("tenant_api_keys")
}
